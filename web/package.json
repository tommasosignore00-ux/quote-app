    "i18next-browser-languagedetector": "^7.2.0",
    "jspdf": "^4.2.0",
    "next": "^14.2.35",
    "openai": "^4.0.0",
    "posthog-js": "^1.357.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
