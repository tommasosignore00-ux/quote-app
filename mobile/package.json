{
  "name": "quote-app-mobile",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start",
    "start:go": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start --tunnel",
    "start:go:lan": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start --lan",
    "android:dev": "bash ../scripts/start-android-dev.sh",
    "android:dev:web": "START_WEB=1 bash ../scripts/start-android-dev.sh",
    "android": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start --android",
    "ios": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start --ios",
    "ios:terminal": "cd ios && xcodebuild -workspace QuoteApp.xcworkspace -scheme QuoteApp -destination 'platform=iOS Simulator,name=iPhone 17 Pro' -configuration Debug -derivedDataPath /tmp/quoteapp-dd build && xcrun simctl boot 'iPhone 17 Pro' || true && xcrun simctl install 'iPhone 17 Pro' /tmp/quoteapp-dd/Build/Products/Debug-iphonesimulator/QuoteApp.app && xcrun simctl launch 'iPhone 17 Pro' com.quoteapp.mobile",
    "web": "NODE_TLS_REJECT_UNAUTHORIZED=0 expo start --web",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~14.0.0",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "~14.0.4",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^23.16.8",
    "intl-pluralrules": "^2.0.1",
    "react": "19.1.0",
    "react-i18next": "^13.5.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-watch-connectivity": "^1.1.0",
    "react-native-webview": "^13.16.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3",
    "patch-package": "^8.0.0",
    "@react-native-community/cli": "^20.1.2",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
